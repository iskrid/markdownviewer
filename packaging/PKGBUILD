# Maintainer: iskrid

pkgname=markdownviewer
pkgver=1.0.0
pkgrel=1
pkgdesc="Minimal, fast Markdown viewer with syntax highlighting and Mermaid diagrams"
arch=(x86_64)
url="https://github.com/iskrid/markdownviewer"
license=(MIT)
depends=(webkit2gtk-4.1 gtk3)
makedepends=(cargo rust)
source=("https://github.com/iskrid/markdownviewer/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=(SKIP)

prepare() {
    export RUSTUP_TOOLCHAIN=stable
    cd "${pkgname}-${pkgver}"
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cd "${pkgname}-${pkgver}"
    cargo build --frozen --release
}

package() {
    cd "${pkgname}-${pkgver}"

    install -Dm755 "target/release/${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
    install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    install -Dm644 "README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
